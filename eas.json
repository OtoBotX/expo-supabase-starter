{
    "cli": {
      "version": ">= 16.0.0",
      "appVersionSource": "local"
    },
    "build": {
      "development": {
        "withoutCredentials": true,
        "android": {
          "buildType": "apk"
        },
        "ios": {
          "simulator": true
        }
      },
      "production": {
        "android": {
          "buildType": "app-bundle"
        },
        "ios": {
          "distribution": "store"
        }
      }
    }
  }
  